<launch>
  <node pkg="canbus_record" type="canbus_record" name="canbus_record" output="screen">
    <param name="device_type" value="4" />
    <param name="device_index" value="0" />
    <param name="can_channel" value="0" />
    <param name="bot_rate" value="500K" />
    <param name="frame_id" value="base_link" />
  </node>
</launch>
